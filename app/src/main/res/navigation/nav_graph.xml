<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.etiotest.ui.theme.splash.SplashFragment"
        android:label="SplashScreen">
        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.etiotest.ui.theme.login.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_login_to_signup"
            app:destination="@id/signupFragment" />
        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/signupFragment"
        android:name="com.example.etiotest.ui.theme.login.SignupFragment"
        android:label="Signup">
        <action
            android:id="@+id/action_signup_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/signupFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.mediora.ui.dashboard.DashboardFragment"
        android:label="Dashboard">
        <action
            android:id="@+id/action_dashboard_to_detail"
            app:destination="@id/testDetailFragment" />
        <action
            android:id="@+id/action_dashboard_to_cartFragment"
            app:destination="@id/cartFragment" />
        <action
            android:id="@+id/action_dashboard_to_profileFragment"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_cartNewFragment"
            app:destination="@id/cartNewFragment" />
    </fragment>

    <fragment
        android:id="@+id/testDetailFragment"
        android:name="com.example.etiotest.ui.theme.main.TestDetailFragment"
        android:label="Test Detail">
        <argument
            android:name="selectedTest"
            app:argType="com.example.etiotest.data.LabTests" />
        <action
            android:id="@+id/action_detail_to_booking"
            app:destination="@id/bookingSlotFragment" />
    </fragment>

    <fragment
        android:id="@+id/bookingSlotFragment"
        android:name="com.example.etiotest.ui.theme.main.BookingSlotFragment"
        android:label="Booking Slot"
        tools:layout="@layout/fragment_booking_slot">

        <action
            android:id="@+id/action_bookingSlotFragment_to_patientListFragment"
            app:destination="@id/patientListFragment" />
        <action
            android:id="@+id/action_booking_to_addAddress"
            app:destination="@id/navigation_add_address"
           />
        <action
            android:id="@+id/action_bookingSlotFragment_to_savedAddressFragment"
            app:destination="@id/savedAddressFragment" />
    </fragment>

    <fragment
        android:id="@+id/navigation_add_address"
        android:name="com.example.etiotest.ui.theme.AddAddressFragment"
        android:label="Add Address"
        tools:layout="@layout/fragment_addaddress" />

    <fragment
        android:id="@+id/cartFragment"
        android:name="com.example.etiotest.ui.theme.main.CartFragment"
        android:label="Cart" >
        <action
            android:id="@+id/action_cartFragment_to_patientSelectionFragment"
            app:destination="@id/patientSelectionFragment" />
        <action
            android:id="@+id/action_cartFragment_to_bookingSlotFragment"
            app:destination="@id/bookingSlotFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.etiotest.ui.theme.main.ProfileFragment">

        <action
            android:id="@+id/action_profileFragment_to_profileDetailsFragment"
            app:destination="@id/profileDetailsFragment" />

        <action
            android:id="@+id/action_profileFragment_to_ordersFragment"
            app:destination="@id/ordersFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileDetailsFragment"
        android:name="com.example.etiotest.ui.theme.main.ProfileDetailsFragment" />

    <action
        android:id="@+id/action_global_loginFragment"
        app:destination="@id/loginFragment"
        app:popUpTo="@id/nav_graph"
        app:popUpToInclusive="true" />


    <fragment
        android:id="@+id/savedAddressFragment"
        android:name="com.example.etiotest.ui.theme.main.SavedAddressesFragment"
        android:label="Saved Address" />

    <fragment
        android:id="@+id/patientListFragment"
        android:name="com.example.etiotest.ui.patient.PatientListFragment"
        android:label="Select Patient"
        tools:layout="@layout/fragment_patient_list" />

    <fragment
        android:id="@+id/ordersFragment"
        android:name="com.example.etiotest.ui.theme.main.OrdersFragment"
        android:label="My Orders" >
        <action
            android:id="@+id/action_ordersFragment_to_orderDetailsFragment"
            app:destination="@id/orderDetailsFragment" />
    </fragment>
    <fragment
        android:id="@+id/orderDetailsFragment"
        android:name="com.example.etiotest.ui.theme.main.OrderDetailsFragment"
        android:label="OrderDetailsFragment" >
        <argument
            android:name="order_id"
            app:argType="string" />
    </fragment>
    <fragment
        android:id="@+id/cartNewFragment"
        android:name="com.example.etiotest.ui.theme.main.CartNewFragment"
        android:label="CartNewFragment" />
    <fragment
        android:id="@+id/patientSelectionFragment"
        android:name="com.example.etiotest.ui.theme.main.PatientSelectionFragment"
        android:label="PatientSelectionFragment" />

</navigation>