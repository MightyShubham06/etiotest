<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color when selected -->
    <solid android:color="#3D8FB8"/>

    <!-- Rounded corners -->
    <corners android:radius="8dp"/>

    <!-- Optional border -->
    <stroke
        android:width="1dp"
        android:color="#2A6F97"/>

    <!-- Padding inside -->
    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="6dp"
        android:bottom="6dp"/>

</shape>