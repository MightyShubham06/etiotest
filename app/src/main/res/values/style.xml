<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Etiotest" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
    </style>
    <style name="CustomTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="textAllCaps">false</item>
    </style>
    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>
    <style name="OtpEditTextStyle">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">45dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/bg_otp_box</item>
        <item name="android:gravity">center</item>
        <item name="android:inputType">number</item>
        <item name="android:maxLength">1</item>
        <item name="android:textColor">#3A93BD</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="LightCalendarTheme" parent="Theme.AppCompat.Light">
        <item name="android:colorControlActivated">#3A93BD</item>
        <item name="android:textColorPrimary">#333333</item>
        <item name="android:textColorSecondary">#666666</item>
    </style>
    <style name="CartInputStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">45dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/bg_cart_input</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColorHint">#666666</item>
        <item name="android:inputType">text</item>
    </style>
    <style name="CustomCalendarTheme" parent="Theme.AppCompat.Light">
        <item name="android:textColorPrimary">#333333</item>
        <item name="android:weekDayTextAppearance">@style/CalendarWeekDay</item>
        <item name="android:selectedWeekBackgroundColor">#3A93BD</item>
        <item name="android:focusedMonthDateColor">#3A93BD</item>
    </style>

    <style name="CalendarWeekDay">
        <item name="android:textColor">#3A93BD</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>
